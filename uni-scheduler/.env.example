# PostgreSQL database used by Prisma in production.
# Example: Vercel Postgres / Neon / Supabase pooled connection string.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require"

# NextAuth secret.
# Generate locally with: openssl rand -base64 32
NEXTAUTH_SECRET=""

# Local: http://localhost:3000
# Production: your Vercel deployment URL, for example https://your-app.vercel.app
NEXTAUTH_URL=""
